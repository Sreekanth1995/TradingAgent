#!/usr/bin/expect -f

set timeout 300
set password "bD?2\$2#TY-v*sx@9"

spawn bash deploy_vultr.sh

# The script does an ssh-keyscan first (no password)
# Step 2: ssh root@65.20.83.74
expect "root@65.20.83.74's password:"
send "$password\r"

# Step 3: rsync
expect "root@65.20.83.74's password:"
send "$password\r"

# Step 4: scp
expect "root@65.20.83.74's password:"
send "$password\r"

# Step 5: ssh
expect "root@65.20.83.74's password:"
send "$password\r"

interact
